{
  "name": "tspace-spear",
  "version": "1.2.2",
  "description": "tspace-spear is a lightweight API framework for Node.js that is fast and highly focused on providing the best developer experience. It utilizes the native HTTP server",
  "main": "./dist/lib/index.js",
  "types": "./dist/lib/index.d.ts",
  "files": [
    "dist"
  ],
  "type": "commonjs",
  "repository": {
    "type": "git",
    "url": "https://github.com/thanathip41/tspace-spear.git"
  },
  "keywords": [
    "tspace",
    "tspace-spear",
    "api",
    "rest api",
    "fast",
    "low overhead"
  ],
  "author": "Thanathip (https://github.com/thanathip41)",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/thanathip41/tspace-spear"
  },
  "homepage": "https://github.com/thanathip41",
  "scripts": {
    "build": "tsc",
    "prepare": "npm run build",
    "release": "npm run build && npm publish",
    "beta": "npm run build && npm publish --tag beta",
    "test:benchmark": "npm run build && node dist/tests/benchmark.test.js",
    "test": "mocha  dist/tests/**/0*.test.js",
    "load": "autocannon -c 100 -d 40 -p 10 localhost:3000",
    "docs": "npx docsify-cli serve docs"
  },
  "engines": {
    "node": ">=14"
  },
  "dependencies": {
    "busboy": "1.6.0",
    "chai-http": "^5.1.2",
    "find-my-way": "8.2.2",
    "mime-types": "2.1.35",
    "on-finished": "2.4.1",
    "reflect-metadata": "0.2.2",
    "swagger-ui-dist": "5.32.0",
    "ws": "8.19.0"
  },
  "devDependencies": {
    "@types/autocannon": "7.12.5",
    "@types/busboy": "1.5.4",
    "@types/chai": "^5.2.3",
    "@types/chai-http": "^4.2.4",
    "@types/express": "4.17.21",
    "@types/jest": "^30.0.0",
    "@types/mime-types": "2.1.4",
    "@types/mocha": "^10.0.10",
    "@types/node": "16.4.0",
    "@types/on-finished": "2.3.4",
    "@types/swagger-ui-dist": "3.30.4",
    "@types/ws": "8.18.1",
    "@types/yargs": "17.0.32",
    "autocannon": "7.15.0",
    "chai": "^4.5.0",
    "docsify-cli": "4.4.4",
    "express": "4.19.2",
    "fastify": "4.28.1",
    "ts-node": "10.9.2",
    "typescript": "5.9.3",
    "yargs": "17.7.2",
    "zod": "4.3.6"
  }
}
